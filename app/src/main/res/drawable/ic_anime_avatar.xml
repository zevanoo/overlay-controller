<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:width="100dp"
    android:height="100dp"
    android:viewportWidth="100"
    android:viewportHeight="100">

    <!-- Circle Clip to maintain perfect circle bounds -->
    <clip-path android:pathData="M 50 2 A 48 48 0 1 1 50 98 A 48 48 0 1 1 50 2 Z" />

    <!-- 1. Background Gradient -->
    <path android:pathData="M0,0h100v100h-100z">
        <aapt:attr name="android:fillColor">
            <gradient
                android:startX="0"
                android:startY="0"
                android:endX="100"
                android:endY="100"
                android:type="linear">
                <item android:color="#F4F8FF" android:offset="0.0" />
                <item android:color="#FFEBF3" android:offset="1.0" />
            </gradient>
        </aapt:attr>
    </path>

    <!-- 2. Back Hair / Shadows -->
    <path
        android:fillColor="#D8DFEE"
        android:pathData="M 15,50 C 10,25 90,25 85,50 C 88,65 92,80 82,90 C 70,100 30,100 18,90 C 8,80 12,65 15,50 Z" />

    <!-- 3. Face Base (Skin) -->
    <path
        android:fillColor="#FFF1EA"
        android:pathData="M 24,50 C 24,66 76,66 76,50 C 76,34 24,34 24,50 Z" />

    <!-- 4. Soft Blush On Cheeks -->
    <path
        android:fillColor="#FFD3DF"
        android:pathData="M 36,55 A 5 4 0 1 1 36,54.9 Z" />
    <path
        android:fillColor="#FFD3DF"
        android:pathData="M 64,55 A 5 4 0 1 1 64,54.9 Z" />

    <!-- 5. Headband -->
    <path
        android:fillColor="#1F1F24"
        android:pathData="M 23,34 C 35,16 65,16 77,34 C 79,37 76,39 74,37 C 63,20 37,20 26,37 C 24,39 21,37 23,34 Z" />

    <!-- 6. Anime Eyes (Red/Pink Glowing Plana Eyes) -->
    <!-- Left Eye Glow -->
    <path android:pathData="M 31,51 C 31,45 43,45 43,51 C 43,57 31,57 31,51 Z">
        <aapt:attr name="android:fillColor">
            <gradient
                android:startX="37"
                android:startY="45"
                android:endX="37"
                android:endY="57"
                android:type="linear">
                <item android:color="#FF1A53" android:offset="0.0" />
                <item android:color="#FF7597" android:offset="1.0" />
            </gradient>
        </aapt:attr>
    </path>
    <!-- Right Eye Glow -->
    <path android:pathData="M 57,51 C 57,45 69,45 69,51 C 69,57 57,57 57,51 Z">
        <aapt:attr name="android:fillColor">
            <gradient
                android:startX="63"
                android:startY="45"
                android:endX="63"
                android:endY="57"
                android:type="linear">
                <item android:color="#FF1A53" android:offset="0.0" />
                <item android:color="#FF7597" android:offset="1.0" />
            </gradient>
        </aapt:attr>
    </path>

    <!-- Concentric Glowing Eye Rings -->
    <path
        android:strokeColor="#FFA6C4"
        android:strokeWidth="0.8"
        android:fillColor="#00000000"
        android:pathData="M 37,51 A 3.5 3.5 0 1 1 37,50.9 Z" />
    <path
        android:strokeColor="#FFA6C4"
        android:strokeWidth="0.8"
        android:fillColor="#00000000"
        android:pathData="M 63,51 A 3.5 3.5 0 1 1 63,50.9 Z" />

    <!-- Eye Pupils & Sparks -->
    <path
        android:fillColor="#FFFFFF"
        android:pathData="M 36,49.5 A 1.2 1.2 0 1 1 36,49.4 Z" />
    <path
        android:fillColor="#FFFFFF"
        android:pathData="M 62,49.5 A 1.2 1.2 0 1 1 62,49.4 Z" />
    <path
        android:fillColor="#FFFFFF"
        android:pathData="M 39,52 A 0.8 0.8 0 1 1 39,51.9 Z" />
    <path
        android:fillColor="#FFFFFF"
        android:pathData="M 65,52 A 0.8 0.8 0 1 1 65,51.9 Z" />

    <!-- Eye Lashes / Eyebrows -->
    <path
        android:fillColor="#242429"
        android:pathData="M 29,48 C 32,43 42,43 45,48 C 46,49.5 44,50 43,49 C 41,45 33,45 31,49 C 30,50 28,49.5 29,48 Z" />
    <path
        android:fillColor="#242429"
        android:pathData="M 55,48 C 58,43 68,43 71,48 C 72,49.5 70,50 69,49 C 67,45 59,45 57,49 C 56,50 54,49.5 55,48 Z" />

    <!-- Cute sleeping/resting smile -->
    <path
        android:strokeColor="#FF6B8B"
        android:strokeWidth="0.8"
        android:strokeLineCap="round"
        android:fillColor="#00000000"
        android:pathData="M 47,56 C 49,57.5 51,57.5 53,56" />

    <!-- 7. White Hair Sweeping Front Bangs (Layered for visual depth) -->
    <!-- Base Hair White -->
    <path
        android:fillColor="#FFFFFF"
        android:pathData="M 18,34 C 28,24 72,24 82,34 C 84,45 80,60 76,65 C 72,50 68,40 68,36 C 58,26 42,26 32,36 C 32,40 28,50 24,65 C 20,60 16,45 18,34 Z" />

    <!-- Dynamic Hair Strands Over Face -->
    <!-- Left bang -->
    <path
        android:fillColor="#FFFFFF"
        android:pathData="M 28,34 C 28,48 37,56 37,60 C 37,61 35,61 35,59 C 33,52 25,45 23,34 Z" />
    <!-- Center left bang -->
    <path
        android:fillColor="#FFFFFF"
        android:pathData="M 44,28 C 45,42 42,52 39,59 C 38,60 37,60 38,58 C 41,50 42,40 42,28 Z" />
    <!-- Center right bang -->
    <path
        android:fillColor="#FFFFFF"
        android:pathData="M 56,28 C 55,42 58,52 61,59 C 62,60 63,60 62,58 C 59,50 58,40 58,28 Z" />
    <!-- Right bang -->
    <path
        android:fillColor="#FFFFFF"
        android:pathData="M 72,34 C 72,48 63,56 63,60 C 63,61 65,61 65,59 C 67,52 75,45 77,34 Z" />

    <!-- Soft Shadows on Hair Strands to look 3D and premium -->
    <path
        android:fillColor="#E1E7F2"
        android:pathData="M 32,36 C 35,42 37,48 37,54 C 36,54 35,50 33,44 C 32,39 31,37 32,36 Z" />
    <path
        android:fillColor="#E1E7F2"
        android:pathData="M 68,36 C 65,42 63,48 63,54 C 64,54 65,50 67,44 C 68,39 69,37 68,36 Z" />

    <!-- Braid Accent on Side -->
    <path
        android:fillColor="#FFFFFF"
        android:pathData="M 78,45 C 81,48 82,51 81,54 C 80,56 78,55 77,53 C 78,51 77,48 75,46 Z" />

    <!-- 8. Sleeping Sleeves / Blanket (Chin resting comfort) -->
    <!-- Cozy Sleeve Left -->
    <path
        android:fillColor="#FFFFFF"
        android:strokeColor="#D3DBE8"
        android:strokeWidth="1"
        android:pathData="M 10,74 C 28,68 46,78 48,95 L 5,95 Z" />
    <!-- Cozy Sleeve Right -->
    <path
        android:fillColor="#FFFFFF"
        android:strokeColor="#D3DBE8"
        android:strokeWidth="1"
        android:pathData="M 90,74 C 72,68 54,78 52,95 L 95,95 Z" />

    <!-- Sleeve Shadows/Folds -->
    <path
        android:strokeColor="#C5D0E3"
        android:strokeWidth="1"
        android:strokeLineCap="round"
        android:fillColor="#00000000"
        android:pathData="M 22,78 C 30,76 38,82 40,88" />
    <path
        android:strokeColor="#C5D0E3"
        android:strokeWidth="1"
        android:strokeLineCap="round"
        android:fillColor="#00000000"
        android:pathData="M 78,78 C 70,76 62,82 60,88" />

    <!-- Dark Desk Rim (Anchor Bottom) -->
    <path
        android:fillColor="#151518"
        android:pathData="M 2,93 H 98 V 100 H 2 Z" />
</vector>
