<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content">

    <!-- MAXIMIZED CONTROLLER OVERLAY -->
    <LinearLayout
        android:id="@+id/overlay_maximized_container"
        android:layout_width="260dp"
        android:layout_height="320dp"
        android:background="@drawable/bg_overlay_max"
        android:orientation="vertical"
        android:padding="12dp"
        android:visibility="visible">

        <!-- Header / Drag Bar -->
        <LinearLayout
            android:id="@+id/header_drag_bar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingBottom="8dp"
            android:background="?android:attr/selectableItemBackground">

            <!-- Small visual indicator for drag -->
            <View
                android:layout_width="16dp"
                android:layout_height="8dp"
                android:background="#444444"
                android:layout_marginEnd="8dp" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="MCO CONTROLLER"
                android:textColor="#FFFFFF"
                android:textSize="12sp"
                android:textStyle="bold"
                android:letterSpacing="0.05" />

            <!-- Minimize Button -->
            <TextView
                android:id="@+id/btn_minimize"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:background="@drawable/bg_button_secondary"
                android:gravity="center"
                android:text="-"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:textStyle="bold"
                android:clickable="true"
                android:focusable="true" />
        </LinearLayout>

        <!-- Divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#333333"
            android:layout_marginBottom="8dp" />

        <!-- Control Row 1: Shift & Mouse Toggle -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="6dp">

            <Button
                android:id="@+id/btn_shift"
                android:layout_width="0dp"
                android:layout_height="38dp"
                android:layout_weight="1.2"
                android:background="@drawable/bg_button_secondary"
                android:text="SHIFT"
                android:textColor="#FFFFFF"
                android:textSize="11sp"
                android:textStyle="bold"
                android:layout_marginEnd="4dp"
                android:insetTop="0dp"
                android:insetBottom="0dp" />

            <Button
                android:id="@+id/btn_mouse_toggle"
                android:layout_width="0dp"
                android:layout_height="38dp"
                android:layout_weight="1.8"
                android:background="@drawable/bg_button_secondary"
                android:text="POINTER: OFF"
                android:textColor="#FFFFFF"
                android:textSize="10sp"
                android:textStyle="bold"
                android:layout_marginStart="4dp"
                android:insetTop="0dp"
                android:insetBottom="0dp" />
        </LinearLayout>

        <!-- Control Row 2: Left Click & Right Click -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="6dp">

            <Button
                android:id="@+id/btn_lclick"
                android:layout_width="0dp"
                android:layout_height="38dp"
                android:layout_weight="1"
                android:background="@drawable/bg_button_secondary"
                android:text="LEFT CLICK"
                android:textColor="#FFFFFF"
                android:textSize="11sp"
                android:textStyle="bold"
                android:layout_marginEnd="4dp"
                android:insetTop="0dp"
                android:insetBottom="0dp" />

            <Button
                android:id="@+id/btn_rclick"
                android:layout_width="0dp"
                android:layout_height="38dp"
                android:layout_weight="1"
                android:background="@drawable/bg_button_secondary"
                android:text="RIGHT CLICK"
                android:textColor="#FFFFFF"
                android:textSize="11sp"
                android:textStyle="bold"
                android:layout_marginStart="4dp"
                android:insetTop="0dp"
                android:insetBottom="0dp" />
        </LinearLayout>

        <!-- Control Row 3: Shift+Left Click & Shift+Right Click -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="8dp">

            <Button
                android:id="@+id/btn_sh_lclick"
                android:layout_width="0dp"
                android:layout_height="38dp"
                android:layout_weight="1"
                android:background="@drawable/bg_button_secondary"
                android:text="SH + LEFT"
                android:textColor="#FFFFFF"
                android:textSize="11sp"
                android:textStyle="bold"
                android:layout_marginEnd="4dp"
                android:insetTop="0dp"
                android:insetBottom="0dp" />

            <Button
                android:id="@+id/btn_sh_rclick"
                android:layout_width="0dp"
                android:layout_height="38dp"
                android:layout_weight="1"
                android:background="@drawable/bg_button_secondary"
                android:text="SH + RIGHT"
                android:textColor="#FFFFFF"
                android:textSize="11sp"
                android:textStyle="bold"
                android:layout_marginStart="4dp"
                android:insetTop="0dp"
                android:insetBottom="0dp" />
        </LinearLayout>

        <!-- Trackpad Touch Area -->
        <FrameLayout
            android:id="@+id/trackpad_area"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:background="@drawable/bg_trackpad"
            android:clickable="true"
            android:focusable="true">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:text="TRACKPAD"
                android:textColor="#444444"
                android:textSize="11sp"
                android:textStyle="bold"
                android:letterSpacing="0.1" />
        </FrameLayout>

    </LinearLayout>

    <!-- MINIMIZED CONTROLLER OVERLAY -->
    <FrameLayout
        android:id="@+id/overlay_minimized_container"
        android:layout_width="54dp"
        android:layout_height="54dp"
        android:background="@drawable/bg_overlay_min"
        android:visibility="gone"
        android:clickable="true"
        android:focusable="true">

        <ImageView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_gravity="center"
            android:src="@drawable/ic_anime_avatar"
            android:scaleType="fitCenter" />
    </FrameLayout>

</FrameLayout>
